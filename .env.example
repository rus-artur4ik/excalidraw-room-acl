# Port the collaboration server listens on
PORT=

# Allowed CORS origin for socket.io (e.g. https://app.example.com). Defaults to *
CORS_ORIGIN=

# Firebase project id used by the Admin SDK. Defaults to excalidraw-team
FIREBASE_PROJECT_ID=excalidraw-team

# Absolute path to the Firebase service account JSON used by
# admin.credential.applicationDefault()
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Shared secret required in the x-internal-secret header on
# POST /internal/acl-changed/:roomId
INTERNAL_SECRET=
